{
  "rules": {
    ".read": false,
    ".write": false,
    "creators": {
      ".read": "auth != null && root.child('creators').child(auth.uid).val() === true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && !root.child('creators').exists()"
      }
    },
    "platformBootstrapped": {
      ".read": true,
      ".write": "auth != null && !data.exists() && root.child('creators').child(auth.uid).val() === true"
    },
    "creatorProfiles": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "companies": {
      ".read": "auth != null && root.child('creators').child(auth.uid).val() === true",
      "$companyId": {
        ".write": "auth != null && root.child('creators').child(auth.uid).val() === true"
      }
    },
    "memberCompany": {
      "$uid": {
        ".read": "auth != null && ( auth.uid === $uid || root.child('creators').child(auth.uid).val() === true )",
        ".write": "auth != null && auth.uid === $uid && !data.exists()"
      }
    },
    "platformInvites": {
      "$emailKey": {
        ".read": "auth != null && ( root.child('creators').child(auth.uid).val() === true || data.child('email').val() === auth.token.email || root.child('memberCompany').child(auth.uid).child('companyId').val() === data.child('companyId').val() )",
        ".write": "auth != null && ( root.child('creators').child(auth.uid).val() === true || data.child('email').val() === auth.token.email || ( !data.exists() && root.child('memberCompany').child(auth.uid).child('companyId').val() === newData.child('companyId').val() && ( root.child('memberCompany').child(auth.uid).child('role').val() === 'masterAdmin' || root.child('memberCompany').child(auth.uid).child('role').val() === 'teamLead' ) && ( newData.child('role').val() !== 'masterAdmin' || root.child('memberCompany').child(auth.uid).child('role').val() === 'masterAdmin' ) ) )"
      }
    },
    "userRouting": {
      "$emailKey": {
        ".read": "auth != null && ( !data.exists() || data.child('email').val() === auth.token.email )",
        ".write": "auth != null && ( !data.exists() || data.child('email').val() === auth.token.email ) && newData.child('email').val() === auth.token.email"
      }
    },
    "meta": {
      ".read": "auth != null && root.child('users').child(auth.uid).exists()",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'masterAdmin'"
    },
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).exists()",
      "$uid": {
        ".write": "auth != null && ( (auth.uid === $uid && !data.exists()) || root.child('users').child(auth.uid).child('role').val() === 'masterAdmin' )"
      }
    },
    "teams": {
      ".read": "auth != null && root.child('users').child(auth.uid).exists()",
      "$teamId": {
        ".write": "auth != null && ( root.child('users').child(auth.uid).child('role').val() === 'masterAdmin' || root.child('teams').child($teamId).child('leadUids').child(auth.uid).val() === true )"
      }
    },
    "projects": {
      ".read": "auth != null && root.child('users').child(auth.uid).exists()",
      "$projectId": {
        ".write": "auth != null && ( root.child('users').child(auth.uid).child('role').val() === 'masterAdmin' || root.child('teams').child(data.child('teamId').val()).child('leadUids').child(auth.uid).val() === true || root.child('teams').child(newData.child('teamId').val()).child('leadUids').child(auth.uid).val() === true )",
        "stages": {
          "$stageId": {
            ".write": "auth != null && root.child('users').child(auth.uid).exists()"
          }
        }
      }
    },
    "pendingInvites": {
      "$emailKey": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'masterAdmin'",
        ".write": "auth != null && ( root.child('users').child(auth.uid).child('role').val() === 'masterAdmin' || root.child('teams').child(data.child('teamId').val()).child('leadUids').child(auth.uid).val() === true || root.child('teams').child(newData.child('teamId').val()).child('leadUids').child(auth.uid).val() === true || data.child('email').val() === auth.token.email )"
      }
    },
    "userProjectIndex": {
      "$emailKey": {
        ".read": "auth != null && root.child('users').child(auth.uid).exists()",
        ".write": "auth != null && root.child('users').child(auth.uid).exists()"
      }
    }
  }
}